  "instructions_to_main_agent": {
    "framework": "React Native (Expo)",
    "language": "JavaScript (or TypeScript if configured)",
    "styling": "StyleSheet.create() only. NO CSS/Tailwind classes.",
    "icons": "Use 'lucide-react-native'. Import components like { Home, Search, PlusCircle, MessageCircle, User, Sprout }.",
    "navigation": "Use Expo Router. File based routing in '/app/frontend/app'.",
    "critical_rules": [
      "Every screen MUST have the 'Watermark' component in the background (zIndex: -1, opacity: 0.06).",
      "Use 'SafeAreaView' from 'react-native-safe-area-context' for all screens.",
      "All interactive elements (TouchableOpacity, Pressable, TextInput) MUST have a 'testID' (or 'accessibilityLabel' if better for testing) prop.",
      "Do not use gradients. Use solid colors or subtle borders.",
      "Commission logic: 5% fee calculated on frontend before payment (visual only) and handled in backend.",
      "Chat is ONLY active after payment. Disable/Hide chat button on listing until purchased."
    ],
    "universal_guidelines": [
      "Avoid default system blue. Use Brand Sage Green (#8DA399) for links and primary actions.",
      "Use 'Alert' from react-native for confirmations, but custom modals for complex interactions.",
      "Ensure touch targets are at least 44x44 points.",
      "KeyboardAvoidView must be used on forms."
    ]
  },
  "watermark_component_code": "import React from 'react';\nimport { View, StyleSheet, Dimensions } from 'react-native';\nimport { Sprout } from 'lucide-react-native';\n\nconst { width } = Dimensions.get('window');\n\nexport const Watermark = () => (\n  <View style={styles.container} pointerEvents=\"none\">\n    <Sprout size={width * 0.6} color=\"#8DA399\" strokeWidth={1} style={{ opacity: 0.06 }} />\n  </View>\n);\n\nconst styles = StyleSheet.create({\n  container: {\n    ...StyleSheet.absoluteFillObject,\n    justifyContent: 'center',\n    alignItems: 'center',\n    zIndex: -1,\n    backgroundColor: 'transparent',\n  },\n});"
}